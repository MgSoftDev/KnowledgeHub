@* Resultados de búsqueda. Embebible: pásale Term. *@

<div class="kh-doc-content" style="max-width:900px;">
    <RadzenText TextStyle="TextStyle.H5" class="rz-mb-3">Resultados de búsqueda</RadzenText>

    @if (Loading)
    {
        <RadzenProgressBarCircular Mode="ProgressBarMode.Indeterminate" Size="ProgressBarCircularSize.Small" />
    }
    else if (Results.Count == 0)
    {
        <p style="color:#6b7280;">No se encontraron páginas para «@Term».</p>
    }
    else
    {
        <p style="color:#6b7280;">@Results.Count resultado(s) para «@Term»:</p>
        @foreach (var r in Results)
        {
            <div style="padding:12px 0;border-bottom:1px solid #eef0f2;">
                @if (OnPageSelected.HasDelegate)
                {
                    @* Embebido: el anfitrión decide qué hacer, sin salir de su pantalla. *@
                    <a href="javascript:void(0)" style="font-weight:600;font-size:1.05rem;"
                       @onclick="@(() => GoPage(r.PagePk))">@r.Title</a>
                }
                else
                {
                    <RadzenLink Path="@KnowledgeHubRoutes.Page(r.PagePk)" Text="@r.Title"
                                style="font-weight:600;font-size:1.05rem;" />
                }
                <div style="color:#6b7280;font-size:0.9rem;margin-top:4px;">@r.Snippet</div>
            </div>
        }
    }
</div>
