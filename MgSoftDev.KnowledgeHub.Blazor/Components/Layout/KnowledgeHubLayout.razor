@inherits LayoutComponentBase

@* Shell de dos columnas para el escenario "portal standalone" (la app ES la documentación).
   Para embeber el módulo dentro del layout de una app anfitriona NO uses este layout: usa
   los componentes de Components/Embedded (KnowledgeHubBrowser, KnowledgeHubNavTree, …). *@

<div class="kh-portal">
    <div class="kh-portal-sidebar">
        <KnowledgeHubNavTree @ref="NavTree">
            <FooterContent>
                <RadzenLink Path="@KnowledgeHubRoutes.Home" Text="Inicio" />
                <RadzenLink Path="@KnowledgeHubRoutes.Diagnostics" Text="Diagnóstico" />
                @if (Options.HeaderActionsComponent is not null)
                {
                    <DynamicComponent Type="@Options.HeaderActionsComponent" />
                }
            </FooterContent>
        </KnowledgeHubNavTree>
    </div>

    <div class="kh-portal-content">
        @Body
    </div>
</div>
