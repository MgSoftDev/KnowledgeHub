@page "/kh/search"

@* Página envoltorio (opt-in vía AdditionalAssemblies). NO declara @layout a propósito:
   así adopta el DefaultLayout del anfitrión. Ruta DEBE coincidir con KnowledgeHubRoutes.Search. *@

<KnowledgeHubSearchResults Term="@Q" />

@code {
    // The routed page reads the term from ?q=; the component takes it as a plain parameter.
    [SupplyParameterFromQuery(Name = "q")]
    public string? Q { get; set; }
}
