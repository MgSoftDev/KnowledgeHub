<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <packageSources>
    <clear />
    <add key="nuget.org" value="https://api.nuget.org/v3/index.json" />
  </packageSources>
</configuration>

<!--
  Nota: para consumir los paquetes ya empaquetados desde el feed local (p. ej. una prueba
  de humo), NO agregues 'artifacts' aquí (rompería el restore en un checkout limpio, ya que
  esa carpeta está en .gitignore y solo la crea `dotnet pack`). En su lugar, en el proyecto
  consumidor usa su propio nuget.config apuntando a la ruta absoluta de la carpeta artifacts.
-->
